"use client";
import { useEffect, useState, useRef } from "react";
import { useSearchParams } from "next/navigation";
import { doc, getDoc, setDoc, addDoc, collection, serverTimestamp } from "firebase/firestore";
import { db } from "@/lib/firebase";

type Status = "idle" | "sending" | "sent" | "error";

export function ChildInner() {
  const sp      = useSearchParams();
  const childId = sp.get("id")   || "";
  const code    = sp.get("code") || "";
  const [childName, setChildName] = useState("...");
  const [sos, setSos]             = useState<Status>("idle");
  const [gpsOk, setGpsOk]        = useState(false);
  const [battery, setBattery]     = useState<number | null>(null);
  const intervalRef               = useRef<NodeJS.Timeout | null>(null);

  useEffect(() => {
    if (!childId) return;
    // Buscar nome do filho
    getDoc(doc(db, "children", childId)).then(snap => {
      if (snap.exists()) setChildName(snap.data().name);
    });

    // Bateria (se disponível)
    if ("getBattery" in navigator) {
      (navigator as any).getBattery().then((b: any) => {
        setBattery(Math.round(b.level * 100));
        b.onlevelchange = () => setBattery(Math.round(b.level * 100));
      });
    }

    // GPS - atualiza a cada 3 minutos
    startGps();
    intervalRef.current = setInterval(startGps, 3 * 60 * 1000);
    return () => { if (intervalRef.current) clearInterval(intervalRef.current); };
  }, [childId]);

  function startGps() {
    if (!navigator.geolocation) return;
    navigator.geolocation.getCurrentPosition(
      pos => sendLocation(pos.coords.latitude, pos.coords.longitude, pos.coords.accuracy),
      () => setGpsOk(false),
      { enableHighAccuracy: true, timeout: 15000 }
    );
  }

  async function sendLocation(lat: number, lng: number, accuracy: number) {
    if (!childId) return;
    setGpsOk(true);
    const loc = { lat, lng, accuracy, battery: battery ?? 0, timestamp: serverTimestamp() };
    // Atualiza localização atual no perfil do filho
    await setDoc(doc(db, "children", childId), { lastLocation: { lat, lng, accuracy, battery: battery ?? 0 }, lastSeen: serverTimestamp() }, { merge: true });
    // Adiciona ao histórico
    await addDoc(collection(db, "locations", childId, "history"), loc);
  }

  async function handleSos() {
    if (sos === "sending") return;
    setSos("sending");
    try {
      // Pegar localização atual
      const pos = await new Promise<GeolocationPosition>((res, rej) =>
        navigator.geolocation.getCurrentPosition(res, rej, { timeout: 10000 })
      );
      const { latitude: lat, longitude: lng } = pos.coords;
      // Atualizar filho
      await sendLocation(lat, lng, pos.coords.accuracy);
      // Criar alerta SOS
      const childSnap = await getDoc(doc(db, "children", childId));
      if (childSnap.exists()) {
        const parentUid = childSnap.data().parentUid;
        await addDoc(collection(db, "alerts"), {
          parentUid, type: "sos", read: false,
          message: `🆘 SOS ativado por ${childName}! Localização enviada.`,
          lat, lng, createdAt: serverTimestamp(),
        });
      }
      setSos("sent");
      setTimeout(() => setSos("idle"), 5000);
    } catch {
      setSos("error");
      setTimeout(() => setSos("idle"), 3000);
    }
  }

  return (
    <div className="min-h-screen flex flex-col items-center justify-center p-6 text-center">
      {/* Header */}
      <div className="sora font-extrabold text-2xl flex items-center gap-2 mb-2">
        <span className="w-3 h-3 rounded-full bg-teal inline-block"/>SafeKid
      </div>
      <p className="text-muted text-sm mb-1">Dispositivo de {childName}</p>

      {/* Status GPS */}
      <div className={`flex items-center gap-2 text-xs px-3 py-1.5 rounded-full border mb-12 mt-2
        ${gpsOk ? "border-teal/30 bg-teal/10 text-teal" : "border-bdr bg-card text-muted"}`}>
        <span className={`w-2 h-2 rounded-full ${gpsOk ? "bg-teal animate-pulse" : "bg-gray-500"}`}/>
        {gpsOk ? "GPS ativo · Enviando localização" : "Aguardando GPS..."}
        {battery !== null && ` · 🔋 ${battery}%`}
      </div>

      {/* Botão SOS */}
      <button
        onPointerDown={handleSos}
        disabled={sos === "sending"}
        className={`w-48 h-48 rounded-full flex flex-col items-center justify-center gap-2 transition-all select-none
          ${sos === "sent"    ? "bg-green-600 scale-95"  :
            sos === "sending" ? "bg-red-900 scale-95"    :
            sos === "error"   ? "bg-orange-700 scale-95" :
            "bg-red-700 active:scale-95 active:bg-red-900"}
          shadow-[0_0_40px_rgba(239,68,68,0.4)]`}
        style={{ touchAction: "none" }}>
        <span className="text-5xl">{sos === "sent" ? "✅" : sos === "error" ? "❌" : "🆘"}</span>
        <span className="sora font-black text-white text-2xl">
          {sos === "sent" ? "ENVIADO!" : sos === "sending" ? "..." : "SOS"}
        </span>
        <span className="text-white/70 text-xs">
          {sos === "sent" ? "Pais avisados" : sos === "error" ? "Erro — tente de novo" : "Toque para emergência"}
        </span>
      </button>

      {/* Aviso legal */}
      <div className="mt-12 max-w-xs">
        <div className="bg-card border border-bdr rounded-xl p-4">
          <p className="text-xs text-muted leading-relaxed">
            🛡️ <strong className="text-white">Este dispositivo está monitorado.</strong><br/>
            A localização é compartilhada com o responsável legal pelo dispositivo.
          </p>
        </div>
        <p className="text-xs text-muted mt-3">Mantenha o navegador aberto para o GPS funcionar.</p>
      </div>
    </div>
  );
}
